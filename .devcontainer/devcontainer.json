{
    "name": "bare-bones-pdf",
    "remoteUser": "pdf",
    "updateRemoteUserUID": true,
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "workspaceMount": "source=${localWorkspaceFolder},target=/home/pdf/bare-bones-pdf,type=bind",
    "workspaceFolder": "/home/pdf/bare-bones-pdf",
    "customizations": {
        "vscode": {
            "extensions": ["ms-vscode.cpptools"],
            "settings": {
                "files.associations": {
                    "*.c": "c",
                    "*.h": "c"
                }
            }
        }
    }
}
